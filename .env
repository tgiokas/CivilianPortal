# ============================================
# CitizenPortal — Environment Variables
# ============================================
# Every variable here maps 1:1 to a Settings class
# in CitizenPortal.Application.Configuration
# ============================================

# ============================================
# .NET Runtime
# ============================================
ASPNETCORE_ENVIRONMENT=Development

# ============================================
# PortalSettings
# ============================================
PORTAL_DB_POSTGRES_USER=portaluser
PORTAL_DB_POSTGRES_PASSWORD=portalpass
PORTAL_DB_POSTGRES_DB=citizenportaldb
PORTAL_DB_CONNECTION=Host=citizen-portal-db;Port=5432;Database=citizenportaldb;Username=portaluser;Password=portalpass;Include Error Detail=true
FRONTEND_REDIRECTURI=http://localhost:3000

# ============================================
# KeycloakSettings
# ============================================
KEYCLOAK_BASEURL=http://keycloak:8080
KEYCLOAK_REALM=CitizenRealm
KEYCLOAK_AUTHORITY=http://keycloak:8080/realms/CitizenRealm
KEYCLOAK_CLIENTID=citizen-portal-app
KEYCLOAK_CLIENTSECRET=
KEYCLOAK_REDIRECTURI=http://localhost:3000/oauth2callback
KEYCLOAK_REQUIRE_HTTPS_METADATA=false

# Keycloak container admin (not part of KeycloakSettings class — used by docker-compose only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_USER=keycloakuser
KEYCLOAK_DB_PASSWORD=keycloakpass
KEYCLOAK_DB_NAME=keycloakdb

# ============================================
# KafkaSettings
# ============================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topics
PORTAL_KAFKA_SUBMITTED_TOPIC=citizen.application.submitted
PORTAL_KAFKA_PROTOCOL_TOPIC=citizen.application.protocol-assigned
PORTAL_KAFKA_NOTIFICATION_TOPIC=citizen.notification.email

# Consumer
PORTAL_KAFKA_CONSUMER_GROUP=citizen-portal-group

# Producer durability
PORTAL_KAFKA_ACKS=All
PORTAL_KAFKA_ENABLE_IDEMPOTENCE=true

# Resilience — reconnect
PORTAL_KAFKA_RECONNECT_BACKOFF_MS=100
PORTAL_KAFKA_RECONNECT_BACKOFF_MAX_MS=10000

# Resilience — socket
PORTAL_KAFKA_SOCKET_CONNECTION_SETUP_TIMEOUT_MS=10000
PORTAL_KAFKA_SOCKET_TIMEOUT_MS=60000

# Resilience — retries
PORTAL_KAFKA_MESSAGE_SEND_MAX_RETRIES=3
PORTAL_KAFKA_RETRY_BACKOFF_MS=100

# Resilience — timeouts
PORTAL_KAFKA_REQUEST_TIMEOUT_MS=5000
PORTAL_KAFKA_MESSAGE_TIMEOUT_MS=10000

# ============================================
# StorageClientSettings
# ============================================
DMS_STORAGE_URL=http://dms-storage:8080

# ============================================
# Serilog / Logging (consumed via appsettings.json overrides)
# ============================================
SERILOG_MINIMUM_LEVEL=Information
SERILOG_ELASTIC_URL=http://elasticsearch:9200
SERILOG_ELASTIC_INDEX_FORMAT=citizen-portal-logs-{0:yyyy.MM.dd}
