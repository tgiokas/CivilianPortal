# ============================================
# PortalSettings
# ============================================
PORTAL_DB_POSTGRES_USER=portaluser
PORTAL_DB_POSTGRES_PASSWORD=portalpass
PORTAL_DB_POSTGRES_DB=citizenportaldb
PORTAL_DB_CONNECTION=Host=citizen-portal-db;Database=citizenportaldb;Username=portaluser;Password=portalpass;Include Error Detail=true
FRONTEND_REDIRECTURI=http://localhost:3000

# ============================================
# KeycloakSettings
# ============================================
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_BASEURL=http://keycloak:8080
KEYCLOAK_REALM=CivilianRealm
KEYCLOAK_CLIENTID=civilian-app
KEYCLOAK_CLIENTSECRET=rpC8odnaEbiwKKxVwcg8yle2bobgFUA2
KEYCLOAK_AUTHORITY=http://keycloak:8080/realms/CivilianRealm
KEYCLOAK_REDIRECTURI=http://localhost/authentication/oauth2callback
#KC_PROXY_HEADERS=xforwarded
#KC_HTTP_ENABLED=false

# Keycloak DB Configuration
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloakdb
KC_DB_USERNAME=keycloakuser
KC_DB_PASSWORD=keycloakpass
KC_DB_POSTGRES_DB=keycloakdb


# ============================================
# KafkaSettings
# ============================================

# Kafka Configuration Resilience - reconnect / socket
KAFKA_BOOTSTRAP_SERVERS=kafka1:19092
PORTAL_KAFKA_RECONNECT_BACKOFF_MS=50
PORTAL_KAFKA_RECONNECT_BACKOFF_MAX_MS=10000
PORTAL_KAFKA_SOCKET_CONNECTION_SETUP_TIMEOUT_MS=10000
PORTAL_KAFKA_SOCKET_TIMEOUT_MS=30000

# Kafka Producer
PORTAL_KAFKA_SUBMITTED_TOPIC=citizen.application.submitted
PORTAL_KAFKA_NOTIFICATION_TOPIC=citizen.notification.email
PORTAL_KAFKA_RETRY_BACKOFF_MS=100
PORTAL_KAFKA_REQUEST_TIMEOUT_MS=30000
PORTAL_KAFKA_MESSAGE_TIMEOUT_MS=120000

# Kafka Consumer
PORTAL_KAFKA_CONSUMER_GROUP=citizen-portal-consumers
PORTAL_KAFKA_PROTOCOL_TOPIC=citizen.application.protocol-assigned
PORTAL_KAFKA_AUTO_OFFSET_RESET=Earliest
PORTAL_KAFKA_SESSION_TIMEOUT_MS=30000
PORTAL_KAFKA_MAX_POLL_INTERVAL_MS=300000

# ============================================
# StorageClientSettings
# ============================================
DMS_STORAGE_URL= http://storage-service:8080

ASPNETCORE_ENVIRONMENT=Development
