{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/CitizenRealm",
    "ClientId": "citizen-portal-app",
    "RequireHttpsMetadata": "false"
  },
  "AllowedHosts": "*"
}
